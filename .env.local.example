OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
# Tên model chat, kiểm tra model hiện có trong tài khoản/provider trước khi đổi
OPENAI_MODEL=gpt-4.1-mini
# Nhà cung cấp bản đồ: "mapbox" (mặc định) hoặc "goong"
NEXT_PUBLIC_MAP_PROVIDER=mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=
# Chỉ cần khi NEXT_PUBLIC_MAP_PROVIDER=goong — lấy tại https://account.goong.io (Maptiles key)
NEXT_PUBLIC_GOONG_MAPTILES_KEY=
ADMIN_USERNAME=
# Tạo bằng: node scripts/hash-password.ts "mật khẩu"
# Next.js tự expand các biến dạng $NAME trong .env.local, nên phải escape mọi ký tự $
# trong hash bcrypt bằng \$ (vd: \$2b\$10\$...) để không bị Next.js làm hỏng giá trị.
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
